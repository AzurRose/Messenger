<Window x:Class="TcpMessenger.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TCP Messenger Client" Height="720" Width="1100" MinHeight="620" MinWidth="900">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Column="0" Grid.RowSpan="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,12,0">
                <GroupBox Header="Connection">
                    <StackPanel>
                        <Label Content="Host" />
                        <TextBox Text="{Binding Host, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />
                        <Label Content="Port" />
                        <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />
                        <Label Content="User name" />
                        <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />
                        <TextBlock Text="{Binding ConnectionStatus}" FontWeight="SemiBold" Margin="0,8,0,8" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Connect" Command="{Binding ConnectCommand}" />
                            <Button Content="Disconnect" Command="{Binding DisconnectCommand}" />
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Active users">
                    <DockPanel LastChildFill="True" MinHeight="220">
                        <ComboBox DockPanel.Dock="Top"
                                  Margin="0,0,0,8"
                                  ItemsSource="{Binding Users}"
                                  SelectedItem="{Binding SelectedPrivateUser}"
                                  IsEditable="False" />
                        <ListBox ItemsSource="{Binding Users}" />
                    </DockPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Column="1" Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <GroupBox Header="Session history">
                <ListBox ItemsSource="{Binding Messages}"
                         DisplayMemberPath="Display"
                         ScrollViewer.VerticalScrollBarVisibility="Auto" />
            </GroupBox>
        </Grid>

        <GroupBox Grid.Column="1" Grid.Row="1" Header="Message" Margin="0,10,12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         MinHeight="38"
                         Text="{Binding MessageText, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="1" Content="Send to all" Command="{Binding SendBroadcastCommand}" />
                <Button Grid.Column="2" Content="Send private" Command="{Binding SendPrivateCommand}" />
            </Grid>
        </GroupBox>

        <ScrollViewer Grid.Column="2" Grid.RowSpan="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="File upload">
                    <StackPanel>
                        <Label Content="Selected file" />
                        <TextBox Text="{Binding SelectedFilePath}" IsReadOnly="True" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Select" Command="{Binding SelectFileCommand}" />
                            <Button Content="Upload" Command="{Binding UploadFileCommand}" />
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Files on server">
                    <Grid MinHeight="360">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ListBox Grid.Row="0" ItemsSource="{Binding Files}" SelectedItem="{Binding SelectedFile}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="4">
                                        <StackPanel>
                                            <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Status}" FontSize="12" />
                                            <ProgressBar Minimum="0" Maximum="100" Height="14" Value="{Binding Progress}" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Button Grid.Row="1" Content="Download selected" Command="{Binding DownloadFileCommand}" Margin="0,8,0,0" />
                    </Grid>
                </GroupBox>

                <GroupBox Header="How to test">
                    <TextBlock TextWrapping="Wrap">
                        1. Start the server project.&#x0a;
                        2. Start two client windows.&#x0a;
                        3. Connect with different names.&#x0a;
                        4. Send public and private messages.&#x0a;
                        5. Upload a file and download it from another client.
                    </TextBlock>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
